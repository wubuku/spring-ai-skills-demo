OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# 使用 `OPENAI_` 前缀表示我们采用的是 OpenAI API 兼容的服务

# 可以将模型从 OpenAI API 兼容模型服务切换为 Anthropic API 兼容模型服务：
# LLM_PROVIDER=anthropic
# Anthropic API 兼容模型配置
ANTHROPIC_API_KEY=sk-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.5

# 启用 Spring AI 原生 MiniMax 支持 - 使用 spring-ai-starter-model-minimax
# LLM_PROVIDER=minimax
# MiniMax 配置
SPRING_AI_MINIMAX_API_KEY=sk-xxx
SPRING_AI_MINIMAX_BASE_URL=https://api.minimaxi.com
SPRING_AI_MINIMAX_CHAT_OPTIONS_MODEL=MiniMax-M2.7

# SiliconFlow 嵌入模型配置（用于 VectorStoreChatMemoryAdvisor）
# ⚠️ 重要提示：URL 千万不要带 /v1 路径！
# Spring AI 的 OpenAiEmbeddingModel 会自动在 base-url 后追加 /v1/embeddings
# 如果配置了 /v1，最终 URL 会变成 https://api.siliconflow.cn/v1/v1/embeddings，导致 404 错误！
# 正确示例：https://api.siliconflow.cn
# 错误示例：https://api.siliconflow.cn/v1 ❌
SILICONFLOW_API_KEY=sk-siliconflow-api-key-here
SILICONFLOW_MODEL=BAAI/bge-m3
SILICONFLOW_DIMENSIONS=1024
SILICONFLOW_URL=https://api.siliconflow.cn


# PostgreSQL 数据库配置
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/spring-ai-skills-demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
# 在测试数据库 spring-ai-skills-demo 中安装 vector 扩展和 pg_jieba 扩展
# create extension vector;
# CREATE EXTENSION pg_jieba;
# SELECT * FROM pg_available_extensions; -- 验证扩展安装
# **注**：目前 pg_jieba 扩展尚未被使用

# 语音识别（转写）模型配置示例
TRANSCRIPTION_BASE_URL=https://open.bigmodel.cn/api/paas
TRANSCRIPTION_API_KEY=your-bigmodel-api-key-here
TRANSCRIPTION_MODEL=glm-asr-2512

# 视觉模型配置示例
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_API_KEY=your-ark-api-key-here
VISION_MODEL=doubao-1-5-vision-pro-32k-250115

# *注意*：
# 修改代码后，一般需要对默认配置和 PostgreSQL 配置分别进行回归测试。
#
# *关于启动后端服务*
#
# 先精准杀死在某个端口上运行的服务端进程：
# lsof -ti:8080 -sTCP:LISTEN | xargs -r kill -9 2>/dev/null; echo "Killed server on port 8080"; sleep 1; lsof -ti:8080 || echo "Port 8080 is free"
#
# 如果要测试基于 PostgreSQL 数据库的配置：
# export SPRING_PROFILES_ACTIVE=postgresql
#
# export $(cat .env | grep -v '^#' | xargs)
# mvn clean package spring-boot:run -DskipTests
